# Copy to .env for local runs (never commit .env)
#
# Agency keys (Secret Manager in production):
#   TRANSIT_MUNI_API_KEY=
# Mobility Database optional enrich:
#   MOBILITYDB_REFRESH_TOKEN=
# Sheet override (defaults to project Sheet CSV export):
#   TRANSIT_SHEET_CSV_URL=
# Browser origins allowed to call the API:
#   CORS_ORIGINS=http://127.0.0.1:8765,https://samueldaly.com,https://samuelgdaly.github.io
# PORT=8080
# GOOGLE_CLOUD_PROJECT=deft-effect-416921
# TRANSIT_DATA_DIR=./data
